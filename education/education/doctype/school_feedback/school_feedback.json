   "fieldtype": "Section Break",
   "label": "Student Information"
  },
  {
   "fieldname": "student",
   "fieldtype": "Link",
   "label": "Student",
   "options": "Student",
   "reqd": 1,
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "student_name",
   "fieldtype": "Data",
   "label": "Student Name",
   "fetch_from": "student.student_name",
   "read_only": 1
  },
  {
   "fieldname": "column_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Open\nIn Review\nResolved\nClosed",
   "default": "Open",
   "in_list_view": 1
  },
  {
   "fieldname": "feedback_section",
   "fieldtype": "Section Break",
   "label": "Feedback Details"
  },
  {
   "fieldname": "category",
   "fieldtype": "Select",
   "label": "Category",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "subcategory",
   "fieldtype": "Select",
   "label": "Subcategory",
   "reqd": 1,
   "in_list_view": 1,
   "depends_on": "eval:doc.category && doc.category != 'Other Issues'"
  },
  {
   "fieldname": "specific_issue",
   "fieldtype": "Select",
   "label": "Specific Issue",
   "reqd": 1,
   "depends_on": "eval:doc.subcategory && doc.category != 'Other Issues'"
  },
  {
   "fieldname": "contextual_details",
   "fieldtype": "JSON",
   "label": "Contextual Details",
   "depends_on": "eval:doc.category != 'Other Issues'"
  },
  {
   "fieldname": "attachment",
   "fieldtype": "Attach Image",
   "label": "Supporting Document/Image"
  },
  {
   "fieldname": "remarks",
   "fieldtype": "Text",
   "label": "Additional Remarks",
   "depends_on": "eval:doc.category != 'Other Issues'"
  },
  {
   "fieldname": "other_feedback_section",
   "fieldtype": "Section Break",
   "label": "Other Issues Details",
   "depends_on": "eval:doc.category == 'Other Issues'"
  },
  {
   "fieldname": "other_issues_feedback",
   "fieldtype": "Long Text",
   "label": "Describe the Issue",
   "depends_on": "eval:doc.category == 'Other Issues'"
  },
  {
   "fieldname": "section_break_config",
   "fieldtype": "Section Break",
   "label": "Configuration",
   "collapsible": 1,
   "depends_on": "eval:frappe.user.has_role('System Manager')"
  },
  {
   "fieldname": "feedback_categories_config",
   "fieldtype": "JSON",
   "label": "Feedback Categories Configuration",
   "description": "JSON configuration for categories, subcategories, and specific issues. Only visible to System Manager.",
   "depends_on": "eval:frappe.user.has_role('System Manager')",
   "default": "{\n  \"Academic Issues\": {\n    \"Curriculum\": [\"Content Difficulty\", \"Pace Too Fast\", \"Pace Too Slow\", \"Missing Topics\"],\n    \"Teaching Methods\": [\"Unclear Explanations\", \"Lack of Examples\", \"No Interactive Activities\", \"Poor Use of Technology\"],\n    \"Assessment\": [\"Unfair Grading\", \"Too Many Tests\", \"Unclear Instructions\", \"Late Feedback\"]\n  },\n  \"Facility Issues\": {\n    \"Classroom\": [\"Poor Lighting\", \"Uncomfortable Seating\", \"Temperature Issues\", \"Cleanliness\"],\n    \"Technology\": [\"Broken Equipment\", \"Internet Issues\", \"Software Problems\", \"Lack of Resources\"],\n    \"Safety\": [\"Security Concerns\", \"Emergency Procedures\", \"Maintenance Issues\", \"Accessibility\"]\n  },\n  \"Administrative Issues\": {\n    \"Communication\": [\"Poor Information Sharing\", \"Late Notifications\", \"Unclear Policies\", \"Language Barriers\"],\n    \"Scheduling\": [\"Conflicting Times\", \"Too Many Classes\", \"Break Time Issues\", \"Event Planning\"],\n    \"Documentation\": [\"Missing Records\", \"Incorrect Information\", \"Slow Processing\", \"Lost Documents\"]\n  },\n  \"Other Issues\": {}\n}"
  }
